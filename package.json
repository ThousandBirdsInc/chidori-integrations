{
  "name": "chidori-integrations",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript integration packages for Chidori agents.",
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "verify": "node scripts/verify-manifest.mjs",
    "test": "npm run build && node scripts/smoke.mjs",
    "vendor:tools": "node scripts/vendor-tools.mjs"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
